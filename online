#!/bin/bash

PID_FILE="bot.pid"
LOG_FILE="hello.log"

run_bot() {
    while true; do
        echo "hello hello $(date)" >> "$LOG_FILE"
        sleep 2
    done
}

start() {
    if [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "Already running ⚠️"
        return
    fi

    echo "Starting bot..."

    nohup bash "$0" run > /dev/null 2>&1 &
    echo $! > "$PID_FILE"

    echo "Started ✅"
}

stop() {
    if [ -f "$PID_FILE" ]; then
        kill $(cat "$PID_FILE") 2>/dev/null
        rm -f "$PID_FILE"
        echo "Stopped 🛑"
    else
        echo "Not running ❌"
    fi
}

status() {
    if [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "Running ✅"
    else
        echo "Stopped ❌"
    fi
}

# hidden mode
if [ "$1" == "run" ]; then
    run_bot
    exit
fi

case "$1" in
    start) start ;;
    stop) stop ;;
    status) status ;;
    *)
        echo "Use: ./online start | stop | status"
        ;;
esac
